[0.017098, "o", "                          _\r\n __      ____ _ _ __ ___ | |_ __\r\n \\ \\ /\\ / / _` | '__/ _ \\| | '_ \\\r\n  \\ V  V / (_| | | | (_) | | | | |\r\n   \\_/\\_/ \\__,_|_|  \\___/|_|_| |_|\r\n\r\n"]
[0.017261, "o", "\u001b[0m"]
[0.017329, "o", "\u001b[2m  credential isolation for AI agents\u001b[0m\r\n\r\n"]
[3.018585, "o", "\r\n\r\n\u001b[1m\u001b[1;33m━━━ WITHOUT WARDN — the problem ━━━\u001b[0m\r\n"]
[4.520068, "o", "\r\n\u001b[2m\u001b[0;36m# Typical setup: real API keys stored in .env or shell environment\u001b[0m\r\n"]
[5.521482, "o", "\r\n\u001b[2m  # .env file sitting on disk\u001b[0m\r\n"]
[5.521615, "o", "  OPENAI_KEY=\u001b[0;31msk-proj-abc123def456ghi789jkl012mno345\u001b[0m\r\n"]
[7.523008, "o", "\r\n\u001b[2m\u001b[0;36m# Any process, agent, or skill can read the real key:\u001b[0m\r\n"]
[8.524577, "o", "\r\n\u001b[0;32m❯\u001b[0m "]
