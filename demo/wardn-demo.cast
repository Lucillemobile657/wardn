[47.436286, "o", "\r\n\u001b[0;32m  ✓ Agent memory: only wdn_placeholder_... (useless)\u001b[0m\r\n"]
[47.436438, "o", "\u001b[0;32m  ✓ Agent logs: only wdn_placeholder_... (useless)\u001b[0m\r\n\u001b[0;32m  ✓ LLM context: only wdn_placeholder_... (useless)\u001b[0m\r\n\u001b[0;32m  ✓ Disk (.env): nothing — key is in encrypted vault\u001b[0m\r\n"]
[50.437822, "o", "\r\n\r\n\u001b[1m\u001b[1;33m━━━ HOW THE PROXY WORKS ━━━\u001b[0m\r\n"]
[51.939712, "o", "\r\n\u001b[2m\u001b[0;36m# wardn runs a local proxy on localhost:7777\u001b[0m\r\n"]
[52.941168, "o", "\r\n\u001b[2m\u001b[0;36m# The agent sends requests through the proxy with placeholder tokens.\u001b[0m\r\n"]
[53.943096, "o", "\r\n\u001b[2m\u001b[0;36m# The proxy swaps placeholders for real keys, forwards the request,\u001b[0m\r\n"]
[54.945022, "o", "\r\n\u001b[2m\u001b[0;36m# then strips real keys from the response before returning to the agent.\u001b[0m\r\n"]
[55.946355, "o", "\r\n\r\n  \u001b[1mRequest flow:\u001b[0m\r\n"]
[55.946487, "o", "  \u001b[2mAgent\u001b[0m ─── \u001b[0;31mwdn_placeholder_a1b2...\u001b[0m ──→ \u001b[0;32mwardn proxy\u001b[0m ──→ \u001b[1msk-proj-real...\u001b[0m ──→ \u001b[2mAPI\u001b[0m\r\n\r\n  \u001b[1mResponse flow:\u001b[0m\r\n  \u001b[2mAgent\u001b[0m ←── \u001b[0;31mwdn_placeholder_a1b2...\u001b[0m ←── \u001b[0;32mwardn proxy\u001b[0m ←── \u001b[1msk-proj-real...\u001b[0m ←── \u001b[2mAPI\u001b[0m\r\n\r\n\r\n  \u001b[2mThe real key exists only inside the proxy process and on the wire to the API.\u001b[0m\r\n  \u001b[2mThe agent never sees, logs, or stores the real key.\u001b[0m\r\n"]
[59.947807, "o", "\r\n\r\n\u001b[1m\u001b[1;33m━━━ PER-AGENT ISOLATION ━━━\u001b[0m\r\n"]
[61.449169, "o", "\r\n\u001b[2m\u001b[0;36m# Each agent gets a unique placeholder for the same credential.\u001b[0m\r\n"]
[62.450678, "o", "\r\n\u001b[2m\u001b[0;36m# If one agent's token leaks, other agents are unaffected.\u001b[0m\r\n"]
