[15.453377, "o", "\r\n\u001b[2m\u001b[0;36m# If the agent is compromised, the attacker has your real key.\u001b[0m\r\n"]
[16.454881, "o", "\r\n\u001b[2m\u001b[0;36m# If the agent logs requests, your key is in plaintext in logs.\u001b[0m\r\n"]
[17.456484, "o", "\r\n\u001b[2m\u001b[0;36m# If an LLM sees the context, your key is in the context window.\u001b[0m\r\n"]
[18.457838, "o", "\r\n\u001b[0;31m  ⚠ Real key exposed everywhere: memory, logs, context, disk\u001b[0m\r\n"]
[21.459605, "o", "\r\n\r\n\u001b[1m\u001b[1;33m━━━ WITH WARDN — the fix ━━━\u001b[0m\r\n"]
