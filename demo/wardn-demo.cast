{"version": 2, "width": 100, "height": 30, "timestamp": 1774440989, "env": {"SHELL": "/usr/bin/zsh", "TERM": "xterm-256color"}, "title": "wardn — credential isolation for AI agents"}
[0.009879, "o", "\u001b[H\u001b[2J\u001b[3J"]
[0.010439, "o", "\r\n\u001b[1m\u001b[0;36m"]
[0.010856, "o", "                          _\r\n __      ____ _ _ __ ___ | |_ __\r\n \\ \\ /\\ / / _` | '__/ _ \\| | '_ \\\r\n  \\ V  V / (_| | | | (_) | | | | |\r\n   \\_/\\_/ \\__,_|_|  \\___/|_|_| |_|\r\n\r\n"]
[0.011, "o", "\u001b[0m"]
[0.011041, "o", "\u001b[2m  credential isolation for AI agents\u001b[0m\r\n"]
[0.011067, "o", "\u001b[2m  agents never see real API keys — structural guarantee, not policy\u001b[0m\r\n"]
[3.012247, "o", "\r\n\r\n\u001b[1m\u001b[1;33m━━━ THE PROBLEM ━━━\u001b[0m\r\n"]
[4.513801, "o", "\r\n\u001b[2m\u001b[0;36m# Every AI agent stores API keys in .env files or environment variables.\u001b[0m\r\n"]
[5.515478, "o", "\r\n\u001b[2m\u001b[0;36m# A compromised agent, malicious skill, or stealer gets full access.\u001b[0m\r\n"]
[7.518375, "o", "\r\n"]
[7.518547, "o", "  \u001b[2m~/.env → OPENAI_KEY=sk-proj-real-key-here     \u001b[0;36m# plaintext!\u001b[0m\r\n  \u001b[2magent  → Authorization: Bearer sk-proj-real... \u001b[0;36m# leaked in logs!\u001b[0m\r\n  \u001b[2mLLM    → \"Use key sk-proj-real...\"             \u001b[0;36m# in context window!\u001b[0m\r\n"]
[10.519902, "o", "\r\n\r\n\u001b[1m\u001b[1;33m━━━ THE FIX ━━━\u001b[0m\r\n"]
[12.021331, "o", "\r\n\u001b[2m\u001b[0;36m# wardn encrypts credentials and gives agents useless placeholder tokens.\u001b[0m\r\n"]
[13.022798, "o", "\r\n\u001b[2m\u001b[0;36m# Real keys are injected at the network proxy layer — agents never touch them.\u001b[0m\r\n"]
[16.025673, "o", "\r\n\r\n\u001b[1m\u001b[1;33m━━━ VAULT MANAGEMENT ━━━\u001b[0m\r\n"]
[17.527046, "o", "\r\n\u001b[2m\u001b[0;36m# Create an AES-256-GCM encrypted vault with Argon2id key derivation\u001b[0m\r\n"]
