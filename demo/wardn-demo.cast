[82.089817, "o", "\r\n"]
[82.395551, "o", "\r\n  WARDN SECURITY AUDIT — Directory\r\n  Scanned: /tmp/wardn-demo-scan\r\n\r\n  EXPOSED CREDENTIALS: 3\r\n  Risk Score: 100/100\r\n\r\n  Severity  | Name                  | Preview              | File\r\n  ----------|----------------------|----------------------|-----\r\n  CRITICAL| OPENAI_KEY           | sk-proj-...i789      | /tmp/wardn-demo-scan/.env\r\n  CRITICAL| ANTHROPIC_KEY        | sk-ant-x...f456      | /tmp/wardn-demo-scan/.env\r\n  CRITICAL| STRIPE_KEY           | sk_live_...0000      | /tmp/wardn-demo-scan/.env\r\n\r\n  DRY RUN — no changes made. Run without --dry-run to migrate.\r\n\r\n"]
[83.897643, "o", "\r\n\u001b[2m\u001b[0;36m# Found exposed keys! wardn can migrate them into the encrypted vault.\u001b[0m\r\n"]
[86.900382, "o", "\r\n\r\n\u001b[1m\u001b[1;33m━━━ HTTP PROXY ━━━\u001b[0m\r\n"]
[88.402025, "o", "\r\n\u001b[2m\u001b[0;36m# wardn serve starts a proxy on localhost:7777\u001b[0m\r\n"]
[89.403667, "o", "\r\n\u001b[2m\u001b[0;36m# It intercepts requests, swaps placeholders for real keys,\u001b[0m\r\n"]
[90.405595, "o", "\r\n\u001b[2m\u001b[0;36m# forwards to the API, then strips real keys from responses.\u001b[0m\r\n"]
[91.406966, "o", "\r\n  \u001b[2mAgent → wdn_placeholder_a1b2... → \u001b[0;32mwardn proxy\u001b[0m → \u001b[2msk-proj-real... → API\u001b[0m\r\n  \u001b[2mAgent ← wdn_placeholder_a1b2... ← \u001b[0;32mwardn proxy\u001b[0m ← \u001b[2msk-proj-real... ← API\u001b[0m\r\n"]
[93.408546, "o", "\r\n\u001b[2m\u001b[0;36m# Start with: wardn serve\u001b[0m\r\n"]
[94.41008, "o", "\r\n\u001b[2m\u001b[0;36m# Or with MCP for Claude Code: wardn serve --mcp --agent my-agent\u001b[0m\r\n"]
[97.413101, "o", "\r\n\r\n\u001b[1m\u001b[1;33m━━━ SECURITY PROPERTIES ━━━\u001b[0m\r\n"]
[98.914739, "o", "\r\n  \u001b[0;32m✓\u001b[0m No credential in agent memory — only placeholders\r\n  \u001b[0;32m✓\u001b[0m No credential on disk in plaintext — AES-256-GCM vault\r\n"]
[98.914911, "o", "  \u001b[0;32m✓\u001b[0m No credential in logs — only placeholder strings\r\n  \u001b[0;32m✓\u001b[0m No credential in LLM context — injected at network layer\r\n  \u001b[0;32m✓\u001b[0m Bounded cost exposure — rate limits per agent\r\n  \u001b[0;32m✓\u001b[0m Credential echo protection — stripped from responses\r\n  \u001b[0;32m✓\u001b[0m Memory safety — zeroed on drop via Zeroize\r\n"]
[101.91644, "o", "\r\n\r\n\u001b[1m\u001b[0;36m  Install:\u001b[0m  cargo install wardn\r\n\u001b[1m\u001b[0;36m  GitHub:\u001b[0m   github.com/rohansx/wardn\r\n\u001b[1m\u001b[0;36m  Crate:\u001b[0m    crates.io/crates/wardn\r\n\r\n"]
